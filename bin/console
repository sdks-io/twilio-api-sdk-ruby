#!/usr/bin/env ruby

# Load the lib folder into Ruby's load path
$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))

# Require the gem
require 'twilio_ap_is'

puts 'TwilioApIs SDK loaded!'
puts 'You can now create a client with: client = TwilioApIs::Client.new'
puts 'Or use from_env: client = TwilioApIs::Client.from_env'

# Start an interactive IRB session
require 'irb'
IRB.start
